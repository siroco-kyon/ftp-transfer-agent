{
  "Watch": {
    "Path": "./watch",
    "IncludeSubfolders": false,
    "AllowedExtensions": [".txt"]
  },
  "Transfer": {
    "Mode": "ftp",
    "Direction": "put",
    "Host": "localhost",
    "Port": 21,
    "Username": "user",
    "Password": "pass",
    "RemotePath": "/remote"
  },
  "Retry": {
    "MaxAttempts": 3,
    "DelaySeconds": 5
  },
  "Hash": {
    "Algorithm": "MD5"
  },
  "Cleanup": {
    "DeleteAfterVerify": false
  },
  "Smtp": {
    "RelayHost": "localhost",
    "RelayPort": 25,
    "UseTls": false,
    "Username": "",
    "Password": "",
    "From": "noreply@example.com",
    "To": ["admin@example.com"]
  },
  "Logging": {
    "Level": "Information",
    "RollingFilePath": "logs/ftp-transfer-.log",
    "MaxBytes": 10485760
  }
}
